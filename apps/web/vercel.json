{
  "redirects": [
    {
      "source": "/scanya/:path*",
      "has": [{ "type": "host", "value": "^(www\\.)?anunciaya\\.mx$" }],
      "destination": "https://s.anunciaya.mx/scanya/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/p/:tipo/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Pinterest|WhatsApp|TelegramBot).*"
        }
      ],
      "destination": "/api/og?tipo=:tipo&id=:id"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}